# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Set USE_REMOTE_DB=1 to use PostgreSQL/MySQL via DATABASE_URL
# Leave it as 0 to use SQLite (default for local development)
USE_REMOTE_DB=0

# DATABASE_URL format examples:
# PostgreSQL: postgresql://username:password@host:port/database_name
# MySQL: mysql://username:password@host:port/database_name
# Example: postgresql://safesphere_user:password123@localhost:5432/safesphere_db
DATABASE_URL=

# Production Settings (uncomment and configure for deployment)
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# USE_REMOTE_DB=1
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
