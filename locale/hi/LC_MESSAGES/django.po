# Fire Safety Module (ADDITIONS)
# =========================

msgid "Fire Safety Module"
msgstr "अग्नि सुरक्षा मॉड्यूल"

msgid "Fire Safety — Prevention, Response & Recovery"
msgstr "अग्नि सुरक्षा — रोकथाम, प्रतिक्रिया और पुनर्प्राप्ति"

msgid "Fire Safety Module | SafeLearn"
msgstr "अग्नि सुरक्षा मॉड्यूल | सेफलर्न"

# Live alert texts (used by alert bar & dismiss button)
msgid "Weather is normal. Stay prepared."
msgstr "मौसम सामान्य है। तैयार रहें।"

msgid "Extreme Heatwave Alert! Avoid going outside. Drink water regularly."
msgstr "अत्यधिक हीटवेव चेतावनी! बाहर जाने से बचें और नियमित रूप से पानी पिएँ।"

msgid "Strong wind alert! Stay indoors and secure loose objects."
msgstr "तेज़ हवाओं की चेतावनी! घर के अंदर रहें और ढीले सामान सुरक्षित करें।"

msgid "Heavy rain risk! Avoid low-lying areas."
msgstr "भारी बारिश का खतरा! निचले इलाकों से दूर रहें।"

msgid "Smoke detected nearby. Review evacuation steps and stay low in smoky rooms."
